{
    "service_name": "virtualserver",
    "api_name": "virtualserver",
    "version": "1.2",
    "client_methods": {
        "list_virtual_servers": {
            "params": ["virtual_server_name", "page", "page_count"],
            "http_method": "GET",
            "path": "/vpc/v2/virtual-servers"
        },
        "describe_virtual_server": {
            "params": ["virtual_server_id"],
            "http_method": "GET",
            "path": "/vpc/v2/virtual-servers/{virtual_server_id}"
        },
        "start_virtual_server": {
            "params": ["virtual_server_id"],
            "http_method": "POST",
            "path": "/vpc/v2/virtual-servers/{virtual_server_id}/start"
        },
        "stop_virtual_server": {
            "params": ["virtual_server_id"],
            "http_method": "POST",
            "path": "/vpc/v2/virtual-servers/{virtual_server_id}/stop"
        },
        "create_server": {
            "params": [
                "image_id", "keypair_name", "name", "networks", "server_type_id", "volumes",
                "file_storage_ids", "lock", "max_count", "metadata", "partition_number",
                "product_category", "product_offering", "security_groups", "server_group_id",
                "tags", "user_data"
            ],
            "required": ["image_id", "keypair_name", "name", "networks", "server_type_id", "volumes"],
            "body_params": [
                "image_id", "keypair_name", "name", "networks", "server_type_id", "volumes",
                "file_storage_ids", "lock", "max_count", "metadata", "partition_number",
                "product_category", "product_offering", "security_groups", "server_group_id",
                "tags", "user_data"
            ],
            "http_method": "POST",
            "path": "/v1/servers",
            "validation": {
                "name": {
                    "type": "regex",
                    "pattern": "^[a-zA-Z0-9-_ ]{1,63}$",
                    "message": "name은 영문/숫자/하이픈/언더스코어/공백 조합, 1~63자이어야 합니다"
                },
                "product_category": {
                    "type": "enum",
                    "values": ["compute", "container"],
                    "message": "지원하지 않는 product_category입니다"
                },
                "product_offering": {
                    "type": "enum",
                    "values": ["virtual_server", "gpu_server", "k8s_vm", "k8s_gpu_vm"],
                    "message": "지원하지 않는 product_offering입니다"
                }
            }
        }
    },
    "resource_methods": {
        "list": {
            "params": ["virtual_server_name", "page", "page_count"],
            "delegates_to": "list_virtual_servers"
        },
        "get": {
            "params": ["virtual_server_id"],
            "delegates_to": "describe_virtual_server"
        },
        "start": {
            "params": ["virtual_server_id"],
            "delegates_to": "start_virtual_server"
        },
        "stop": {
            "params": ["virtual_server_id"],
            "delegates_to": "stop_virtual_server"
        },
        "create": {
            "params": [
                "image_id", "keypair_name", "name", "networks", "server_type_id", "volumes",
                "file_storage_ids", "lock", "max_count", "metadata", "partition_number",
                "product_category", "product_offering", "security_groups", "server_group_id",
                "tags", "user_data"
            ],
            "delegates_to": "create_server"
        }
    },
    "paginators": {
        "list_virtual_servers": {
            "input_token":      "page",
            "limit_key":        "page_count",
            "result_key":       "contents",
            "starting_token":   0,
            "default_page_size": 20
        }
    },
    "waiters": {
        "virtual_server_running": {
            "operation":    "describe_virtual_server",
            "delay":        10,
            "max_attempts": 30,
            "acceptors": [
                {
                    "matcher":  "path",
                    "argument": "virtualServerState",
                    "expected": "RUNNING",
                    "state":    "success"
                },
                {
                    "matcher":  "path",
                    "argument": "virtualServerState",
                    "expected": "ERROR",
                    "state":    "failure"
                }
            ]
        },
        "virtual_server_stopped": {
            "operation":    "describe_virtual_server",
            "delay":        10,
            "max_attempts": 30,
            "acceptors": [
                {
                    "matcher":  "path",
                    "argument": "virtualServerState",
                    "expected": "STOPPED",
                    "state":    "success"
                },
                {
                    "matcher":  "path",
                    "argument": "virtualServerState",
                    "expected": "ERROR",
                    "state":    "failure"
                }
            ]
        }
    },
    "collections": {
        "virtual_servers": {
            "method":     "list_virtual_servers",
            "result_key": "contents",
            "page_param": "page",
            "size_param": "page_count"
        }
    }
}
