{
    "service_name": "ec2",
    "client_methods": {
        "describe_instances": {
            "params": ["instance_id"],
            "validation": {
                "instance_id": {
                    "type": "regex",
                    "pattern": "^i-[0-9a-f]{8,17}$",
                    "message": "instance_id 형식이 올바르지 않습니다 (예: i-1234567890abcdef0)"
                }
            },
            "response": {
                "InstanceId": "$instance_id",
                "InstanceType": "t3.micro",
                "State": {"Name": "running"},
                "PublicIpAddress": "54.123.45.67",
                "PrivateIpAddress": "10.0.0.1"
            }
        },
        "run_instances": {
            "params": ["instance_type", "private_ip_address"],
            "validation": {
                "instance_type": {
                    "type": "enum",
                    "values": ["t3.micro", "t3.small", "t3.medium", "t3.large", "t3.xlarge"],
                    "message": "지원하지 않는 instance_type입니다"
                },
                "private_ip_address": {
                    "type": "regex",
                    "pattern": "^(10\\.\\d{1,3}|172\\.(1[6-9]|2[0-9]|3[01])|192\\.168)\\.\\d{1,3}\\.\\d{1,3}$",
                    "message": "유효한 Private IP 형식이 아닙니다 (예: 10.0.1.50, 192.168.0.1)"
                }
            },
            "response": {
                "InstanceId": "i-new1234567890ab",
                "InstanceType": "$instance_type",
                "PrivateIpAddress": "$private_ip_address",
                "State": {"Name": "pending"}
            }
        },
        "start_instances": {
            "params": ["instance_id"],
            "validation": {
                "instance_id": {
                    "type": "regex",
                    "pattern": "^i-[0-9a-f]{8,17}$",
                    "message": "instance_id 형식이 올바르지 않습니다 (예: i-1234567890abcdef0)"
                }
            },
            "response": {
                "StartingInstances": [
                    {"InstanceId": "$instance_id", "CurrentState": {"Name": "pending"}}
                ]
            }
        },
        "stop_instances": {
            "params": ["instance_id"],
            "validation": {
                "instance_id": {
                    "type": "regex",
                    "pattern": "^i-[0-9a-f]{8,17}$",
                    "message": "instance_id 형식이 올바르지 않습니다 (예: i-1234567890abcdef0)"
                }
            },
            "response": {
                "StoppingInstances": [
                    {"InstanceId": "$instance_id", "CurrentState": {"Name": "stopping"}}
                ]
            }
        },
        "terminate_instances": {
            "params": ["instance_id"],
            "validation": {
                "instance_id": {
                    "type": "regex",
                    "pattern": "^i-[0-9a-f]{8,17}$",
                    "message": "instance_id 형식이 올바르지 않습니다 (예: i-1234567890abcdef0)"
                }
            },
            "response": {
                "TerminatingInstances": [
                    {"InstanceId": "$instance_id", "CurrentState": {"Name": "shutting-down"}}
                ]
            }
        }
    },
    "resource_methods": {
        "Instance": {
            "params": ["instance_id"],
            "delegates_to": "describe_instances"
        },
        "launch": {
            "params": ["instance_type", "private_ip_address"],
            "delegates_to": "run_instances"
        },
        "start": {
            "params": ["instance_id"],
            "delegates_to": "start_instances"
        },
        "stop": {
            "params": ["instance_id"],
            "delegates_to": "stop_instances"
        },
        "terminate": {
            "params": ["instance_id"],
            "delegates_to": "terminate_instances"
        }
    }
}
