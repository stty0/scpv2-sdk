{
    "service_name": "vpc",
    "api_name": "vpc",
    "version": "1.2",
    "client_methods": {
        "list_vpcs": {
            "params": ["size", "page", "sort", "id", "name", "state", "cidr"],
            "http_method": "GET",
            "path": "/v1/vpcs"
        },
        "create_vpc": {
            "params": ["name", "cidr", "description", "tags"],
            "required": ["name", "cidr"],
            "body_params": ["name", "cidr", "description", "tags"],
            "http_method": "POST",
            "path": "/v1/vpcs",
            "validation": {
                "name": {
                    "type": "regex",
                    "pattern": "^[a-zA-Z0-9][a-zA-Z0-9\\-]{1,28}[a-zA-Z0-9]$",
                    "message": "name은 영문/숫자/하이픈 조합, 3~30자이어야 합니다"
                },
                "cidr": {
                    "type": "regex",
                    "pattern": "^(10\\.\\d{1,3}|172\\.(1[6-9]|2[0-9]|3[01])|192\\.168)\\.\\d{1,3}\\.\\d{1,3}/(8|9|1[0-9]|2[0-8])$",
                    "message": "cidr은 사설 IP 대역(10.x, 172.16-31.x, 192.168.x)이어야 하며 /8~/28 범위이어야 합니다"
                }
            }
        },
        "delete_vpc": {
            "params": ["vpc_id"],
            "required": ["vpc_id"],
            "http_method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}"
        }
    },
    "resource_methods": {
        "list": {
            "params": ["size", "page", "sort", "id", "name", "state", "cidr"],
            "delegates_to": "list_vpcs"
        },
        "create": {
            "params": ["name", "cidr", "description", "tags"],
            "delegates_to": "create_vpc"
        },
        "delete": {
            "params": ["vpc_id"],
            "delegates_to": "delete_vpc"
        }
    },
    "paginators": {
        "list_vpcs": {
            "input_token":      "page",
            "limit_key":        "size",
            "result_key":       "vpcs",
            "starting_token":   0,
            "default_page_size": 20
        }
    },
    "waiters": {
        "vpc_active": {
            "operation":    "list_vpcs",
            "delay":        5,
            "max_attempts": 20,
            "acceptors": [
                {
                    "matcher":  "path",
                    "argument": "contents[0].vpcState",
                    "expected": "ACTIVE",
                    "state":    "success"
                },
                {
                    "matcher":  "path",
                    "argument": "contents[0].vpcState",
                    "expected": "ERROR",
                    "state":    "failure"
                }
            ]
        },
        "vpc_deleted": {
            "operation":    "list_vpcs",
            "delay":        5,
            "max_attempts": 20,
            "acceptors": [
                {
                    "matcher":  "path",
                    "argument": "contents",
                    "expected": null,
                    "state":    "success"
                }
            ]
        }
    },
    "collections": {
        "vpcs": {
            "method":     "list_vpcs",
            "result_key": "vpcs",
            "page_param": "page",
            "size_param": "size"
        }
    }
}
